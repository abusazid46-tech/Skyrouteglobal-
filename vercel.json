{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/domestic", "destination": "/domestic.html" },
    { "source": "/international", "destination": "/international.html" },
    { "source": "/honeymoon", "destination": "/honeymoon.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/(.*)", "destination": "/404.html" }
  ],
  "cleanUrls": true
}
